# VoxOrder Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to GitHub — it contains secret keys

# ─────────────────────────────────────────
# TWILIO
# Get these from: https://console.twilio.com
# ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# ─────────────────────────────────────────
# GOOGLE CLOUD (for STT upgrade — Week 2)
# Get these from: https://console.cloud.google.com
# Enable: Speech-to-Text API
# Create a service account and download JSON key
# ─────────────────────────────────────────
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ─────────────────────────────────────────
# DATABASE
# SQLite (POC default — no setup needed)
# PostgreSQL (MVP — uncomment when ready)
# ─────────────────────────────────────────
# SQLite (default, auto-created)
DATABASE_URL=sqlite:///orders.db

# PostgreSQL (uncomment for MVP)
# DATABASE_URL=postgresql://voxorder:voxorder123@localhost:5432/voxorder

# ─────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
PORT=8080

# ─────────────────────────────────────────
# TUNNEL (for local development)
# Your ngrok/serveo public URL
# Update this every time you restart the tunnel
# ─────────────────────────────────────────
SERVER_URL=https://your-tunnel-url.ngrok-free.app
